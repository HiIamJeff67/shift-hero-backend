# ============================== Project Basic Environment Variables ============================== #
WORKSPACE_DIR=/shift-hero
APP_NAME=shift-hero
# ============================== Project Basic Environment Variables ============================== #

# ============================== Database Environment Variables ============================== #
DB_HOST=shift-hero-db
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=shift-hero-db
DB_PORT=6543
# ============================== Database Environment Variables ============================== #

# ============================== API Environment Variables ============================== #
API_BASE_PATH=api
GIN_DOMAIN=0.0.0.0
GIN_PORT=7777
GRAPHQL_PLAYGROUND_PORT=8080
GIN_TRUSTED_PROXIES=172.30.0.10/32
# ============================== API Environment Variables ============================== #

# ============================== Redis Environment Variables ============================== #
REDIS_HOST=shift-hero-redis
REDIS_PORT=6379
REDIS_PASSWORD=redis
REDIS_INIT_DB=0
# ============================== Redis Environment Variables ============================== #

# ============================== LGTM Environment Variables ============================== #
LOKI_PORT=3100
TEMPO_PORT=3200
MIMIR_PORT=9009
OTEL_COLLECTOR_GRPC_PORT=4317
OTEL_COLLECTOR_HTTP_PORT=4318
GRAFANA_PORT=3000
# ============================== LGTM Environment Variables ============================== #

# ============================== Nginx Environment Variables ============================== #
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
# ============================== Nginx Environment Variables ============================== #

# ============================== Docker Environment Variables ============================== #
DOCKER_REDIS_SERVICE_NAME=shift-hero-redis
DOCKER_DB_SERVICE_NAME=shift-hero-db
DOCKER_API_SERVICE_NAME=shift-hero-api
DOCKER_NGINX_SERVICE_NAME=shift-hero-nginx
DOCKER_LOKI_SERVICE_NAME=shift-hero-loki
DOCKER_TEMPO_SERVICE_NAME=shift-hero-tempo
DOCKER_MIMIR_SERVICE_NAME=shift-hero-mimir
DOCKER_OTEL_COLLECTOR_SERVICE_NAME=shift-hero-otel-collector
DOCKER_GRAFANA_SERVICE_NAME=shift-hero-grafana
DOCKER_REDIS_PORT=6379
DOCKER_DB_PORT=5432
DOCKER_GIN_PORT=7777
DOCKER_NGINX_HTTP_PORT=80
DOCKER_NGINX_HTTPS_PORT=443
DOCKER_LOKI_PORT=3100
DOCKER_TEMPO_PORT=3200
DOCKER_MIMIR_PORT=9009
DOCKER_OTEL_COLLECTOR_GRPC_PORT=4317
DOCKER_OTEL_COLLECTOR_HTTP_PORT=4318
DOCKER_GRAFANA_PORT=3000
TEST_DOCKER_DB_PORT=5432
ENTRYPOINT_CMD=./shift-hero
GF_SECURITY_ADMIN_PASSWORD=admin
GF_FEATURE_TOGGLE_ENABLE=traceqlEditor
# ============================== Docker Environment Variables ============================== #

# ============================== Token Environment Variables ============================== #
JWT_ACCESS_TOKEN_SECRET_KEY=replace-with-a-long-random-string
JWT_REFRESH_TOKEN_SECRET_KEY=replace-with-a-long-random-string
CSRF_TOKEN_SECRET_KEY=replace-with-a-random-string
# ============================== Token Environment Variables ============================== #

# ============================== Email Environment Variables ============================== #
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
APP_OFFICIAL_NAME=Backend Starter
APP_OFFICIAL_GMAIL=noreply@example.com
APP_OFFICIAL_GOOGLE_PASSWORD=
APP_OFFICIAL_GOOGLE_APPLICATION_PASSWORD=
APP_OFFICIAL_WEBSITE_URL=http://localhost:7777
APP_OFFICIAL_LOGIN_URL=http://localhost:7777/login
APP_OFFICIAL_HELP_URL=http://localhost:7777/help
APP_OFFICIAL_SUPPORT_URL=http://localhost:7777/support
APP_OFFICIAL_PRIVACY_URL=http://localhost:7777/privacy
APP_OFFICIAL_TERMS_URL=http://localhost:7777/terms
APP_OFFICIAL_SECURITY_URL=http://localhost:7777/security
APP_OFFICIAL_SECURITY_REVIEW_URL=http://localhost:7777/security/review
APP_OFFICIAL_ACCOUNT_SETTINGS_URL=http://localhost:7777/account/settings
APP_OFFICIAL_SUPPORT_EMAIL=support@example.com
APP_OFFICIAL_SECURITY_EMAIL=security@example.com
# ============================== Email Environment Variables ============================== #

# ============================== Security Environment Variables ============================== #
ALLOWED_DOMAINS=http://localhost:7777,http://localhost:8080
STORAGE_KEY_SALT=replace-with-random-salt
# ============================== Security Environment Variables ============================== #

# ============================== OAuth Environment Variables ============================== #
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GOOGLE_REDIRECT_URL=http://localhost:7777/api/development/v1/redirect/google
# ============================== OAuth Environment Variables ============================== #

